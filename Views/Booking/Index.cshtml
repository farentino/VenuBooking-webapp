@model IEnumerable<VenuBooking.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
}

<h1>Bookings</h1>

<form asp-action="Index" method="get" class="mb-4">

    <div class="row mb-2">

        <div class="col-md-3">
            <input type="text"
                   name="search"
                   value="@ViewBag.Search"
                   class="form-control"
                   placeholder="Booking ID or Event Name" />
        </div>

        <div class="col-md-3">
            <select name="eventTypeId" class="form-control" asp-items="ViewBag.EventTypeID">
                <option value="">All Event Types</option>
            </select>
        </div>

        <div class="col-md-3">
            <select name="venueId" class="form-control" asp-items="ViewBag.VenueID">
                <option value="">All Venues</option>
            </select>
        </div>

    </div>

    <div class="row mb-2">

        <div class="col-md-3">
            <input type="date"
                   name="startDate"
                   value="@ViewBag.StartDate"
                   class="form-control" />
        </div>

        <div class="col-md-3">
            <input type="date"
                   name="endDate"
                   value="@ViewBag.EndDate"
                   class="form-control" />
        </div>

        <div class="col-md-3">
            <button type="submit" class="btn btn-secondary">Filter</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        </div>

    </div>

</form>

<p>
    <a asp-action="Create" class="btn btn-primary">Create Booking</a>
</p>

<table class="table table-bordered table-striped align-middle">
    <thead class="table-dark">
        <tr>
            <th>Booking ID</th>
            <th>Venue</th>
            <th>Location</th>
            <th>Capacity</th>
            <th>Event</th>
            <th>Event Type</th>
            <th>Event Start</th>
            <th>Event End</th>
            <th>Booking Date</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.BookingID</td>
                <td>@item.Venue?.Name</td>
                <td>@item.Venue?.Location</td>
                <td>@item.Venue?.Capacity</td>
                <td>@item.Event?.Name</td>
                <td>@item.Event?.EventType?.Name</td>
                <td>@item.Event?.StartDate.ToShortDateString()</td>
                <td>@item.Event?.EndDate.ToShortDateString()</td>
                <td>@item.BookingDate.ToShortDateString()</td>
            </tr>
        }
    </tbody>
</table>